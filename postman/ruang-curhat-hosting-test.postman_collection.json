{
  "info": {
    "_postman_id": "50dc9890-4b6f-4ebe-9000-6f6061110d8a",
    "name": "Ruang Curhat - Hosting API Test",
    "description": "Smoke test endpoints untuk memastikan Laravel API, runtime, database, dan CRUD bisa berjalan di shared hosting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health Check",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/testing/health",
        "description": "Cek apakah API Laravel bisa diakses."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('API status is ok', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Runtime Info",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/testing/runtime",
        "description": "Cek versi PHP, Laravel, environment, dan timezone tanpa menampilkan secret."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Runtime fields are present', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('php_version');",
              "    pm.expect(json).to.have.property('laravel_version');",
              "    pm.expect(json).to.have.property('environment');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Database Connection",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/testing/database",
        "description": "Cek apakah koneksi database di hosting sudah berhasil."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Database status is ok', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - List Testing Notes",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/testing/notes",
        "description": "Ambil data testing notes dari database."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Data is an array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.data).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Create Testing Note",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Hosting Test\",\n  \"message\": \"Created from Postman on arjuno.my.id\"\n}"
        },
        "url": "{{base_url}}/api/testing/notes",
        "description": "Buat data baru di tabel testing_notes."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Created note id is saved', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.data).to.have.property('id');",
              "    pm.collectionVariables.set('testing_note_id', json.data.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Show Testing Note",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/testing/notes/{{testing_note_id}}",
        "description": "Ambil satu data yang baru dibuat."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Shown note id matches saved id', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(String(json.data.id)).to.eql(String(pm.collectionVariables.get('testing_note_id')));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Update Testing Note",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Hosting Test Updated\",\n  \"message\": \"Updated from Postman on arjuno.my.id\"\n}"
        },
        "url": "{{base_url}}/api/testing/notes/{{testing_note_id}}",
        "description": "Update data testing note di database."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Note is updated', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.data.name).to.eql('Postman Hosting Test Updated');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - Delete Testing Note",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/testing/notes/{{testing_note_id}}",
        "description": "Hapus data testing note dari database."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Delete message is returned', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.message).to.eql('Testing note deleted.');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://arjuno.my.id",
      "type": "string"
    },
    {
      "key": "testing_note_id",
      "value": "",
      "type": "string"
    }
  ]
}
